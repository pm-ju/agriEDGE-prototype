### 3.5 `src/models/sktime_classifiers.py`

```python
"""sktime-based classifier wrappers for foreign object detection.

This module provides two classifiers:
1. MLPClassifierTorch — deep learning MLP from sktime (primary)
2. TimeSeriesForestClassifier — ensemble baseline for comparison

Both are wrapped in a consistent interface for the evaluation pipeline.
"""

from sktime.classification.deep_learning.mlp import MLPClassifierTorch
from sktime.classification.interval_based import TimeSeriesForestClassifier

from src.config import (
    MLP_HIDDEN_DIM,
    MLP_N_LAYERS,
    MLP_DROPOUT,
    MLP_NUM_EPOCHS,
    MLP_BATCH_SIZE,
    MLP_LR,
    MLP_OPTIMIZER,
    MLP_CRITERION,
    RANDOM_SEED,
)


def build_mlp_classifier():
    """Build the sktime MLPClassifierTorch with project hyperparameters.

    This is the PRIMARY model for the project — a PyTorch-based MLP
    running inside sktime's framework.

    Returns
    -------
    clf : MLPClassifierTorch
        Configured but untrained classifier.
    """
    return MLPClassifierTorch(
        hidden_dim=MLP_HIDDEN_DIM,
        n_layers=MLP_N_LAYERS,
        dropout=MLP_DROPOUT,
        num_epochs=MLP_NUM_EPOCHS,
        batch_size=MLP_BATCH_SIZE,
        lr=MLP_LR,
        optimizer=MLP_OPTIMIZER,
        criterion=MLP_CRITERION,
        activation=None,          # No output activation (CrossEntropyLoss handles it)
        activation_hidden="relu",
        callbacks="ReduceLROnPlateau",
        verbose=True,
        random_state=RANDOM_SEED,
    )


def build_tsf_baseline():
    """Build a TimeSeriesForestClassifier as a non-deep-learning baseline.

    This provides a comparison point: how does a traditional ensemble method
    compare to the deep learning approach?

    Returns
    -------
    clf : TimeSeriesForestClassifier
        Configured but untrained classifier.
    """
    return TimeSeriesForestClassifier(
        n_estimators=200,
        random_state=RANDOM_SEED,
    )
```

